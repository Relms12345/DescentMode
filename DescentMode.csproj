<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Library</OutputType>
    <RootNamespace>DescentMode</RootNamespace>
    <AssemblyName>DescentMode</AssemblyName>
    <TargetFramework>net4.8</TargetFramework>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>
  <PropertyGroup>
    <KSPBT_ModRoot>$(MSBuildProjectDirectory)/GameData/DescentMode/</KSPBT_ModRoot>
    <KSPBT_ModPluginFolder>Plugins</KSPBT_ModPluginFolder>
  </PropertyGroup>
  <ItemGroup>
    <KSPVersionFile Include="GameData/DescentMode/DescentMode.version">
      <Destination>$(KSPBT_ModRoot)/DescentMode.version</Destination>
    </KSPVersionFile>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="KSPBuildTools" Version="1.1.1" />
  </ItemGroup>
</Project>
